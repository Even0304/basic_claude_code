# ============================================================================
# OpenAI-Compatible API Configuration (for Kimi, Claude, or any compatible)
# ============================================================================

# Method 1: Using third-party API relay service (e.g., miromind.site)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.miromind.site/v1
LLM_MODEL=moonshotai/kimi-k2.5

# Method 2: Using official Moonshot AI API
# OPENAI_API_KEY=your-moonshot-api-key
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# ============================================================================
# Anthropic Configuration (for Claude)
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-opus-4-6

# ============================================================================
# Default Provider
# ============================================================================
# Options: kimi, claude
PROVIDER=kimi

# ============================================================================
# Debug Mode
# ============================================================================
DEBUG=false
